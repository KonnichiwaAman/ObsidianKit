    "docx": "^9.6.1",
    "heic2any": "0.0.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
